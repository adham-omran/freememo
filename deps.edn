{:deps    {com.hyperfiddle/electric       {:mvn/version "v3-alpha-SNAPSHOT"}
           org.clojure/clojure            {:mvn/version "1.12.0"}
           org.clojure/clojurescript      {:mvn/version "1.11.121"}
           ring/ring                      {:mvn/version "1.15.3"} ; to serve the app
           ch.qos.logback/logback-classic {:mvn/version "1.4.14"}
           com.github.seancorfield/next.jdbc {:mvn/version "1.3.939"}
           com.github.seancorfield/honeysql {:mvn/version "2.6.1203"}
           org.postgresql/postgresql {:mvn/version "42.7.3"}
           com.zaxxer/HikariCP {:mvn/version "5.1.0"}
           org.apache.pdfbox/pdfbox {:mvn/version "3.0.3"}
           com.levigo.jbig2/levigo-jbig2-imageio {:mvn/version "2.0"}
           net.clojars.wkok/openai-clojure {:mvn/version "0.23.0"}
           clj-http/clj-http {:mvn/version "3.12.3"}
           cheshire/cheshire {:mvn/version "5.12.0"}
           org.jsoup/jsoup {:mvn/version "1.17.2"}}
 :paths   ["src" "resources"]
 :aliases {:dev {:extra-paths ["src-dev"] :extra-deps  {thheller/shadow-cljs {:mvn/version "2.26.2"}}}
           :prod {:extra-paths ["src-prod"] :jvm-opts ["-Xss4m"]}
           :build ; use `clj -X:prod:build build-client`, NOT -T!
           {:extra-paths ["src-build"]
            :ns-default  build
            :jvm-opts    ["-Xss4m"]
            :extra-deps  {thheller/shadow-cljs          {:mvn/version "2.26.2"}
                          io.github.clojure/tools.build {:mvn/version "0.10.8"}}}
           :jetty9 {:override-deps {ring/ring {:mvn/version "1.9.6"}}
                    :extra-deps    {ring/ring-jetty-adapter                       {:mvn/version "1.8.2"}
                                    ring/ring-servlet                             {:mvn/version "1.8.2"}
                                    org.eclipse.jetty.websocket/websocket-server  {:mvn/version "9.4.31.v20200723"} ; matching jetty version from ring-jetty-adapter
                                    org.eclipse.jetty.websocket/websocket-servlet {:mvn/version "9.4.31.v20200723"}}}
           :private {:override-deps {com.hyperfiddle/electric {:local/root "../electric"}}}}
 :mvn/repos
 {"clojars" {:url "https://repo.clojars.org/" :snapshots {:enabled true :update :always}}}}
