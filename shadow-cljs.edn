{:nrepl {:port 9009}
 :builds
 {:dev  {:target :browser
         :devtools {:loader-mode :default, :watch-dir "resources/public"}
         :output-dir "resources/public/freememo/js"
         :asset-path "/freememo/js"
         :modules {:shared   {:entries []}
                   :main     {:entries [dev]
                              :init-fn dev/-main
                              :depends-on #{:shared}}
                   :metadata {:entries [dev-metadata]
                              :init-fn dev-metadata/-main
                              :depends-on #{:shared}}}
         :build-hooks [(hyperfiddle.electric.shadow-cljs.hooks3/reload-clj)]}
  :dev-jetty9 {:target :browser
               :devtools {:loader-mode :default, :watch-dir "resources/public"}
               :output-dir "resources/public/freememo/js"
               :asset-path "/freememo/js"
               :modules {:main {:entries [dev-jetty9] :init-fn dev-jetty9/-main}}
               :build-hooks [(hyperfiddle.electric.shadow-cljs.hooks3/reload-clj)]}
  :prod {:target :browser
         :output-dir "resources/public/freememo/js"
         :asset-path "/freememo/js"
         :modules {:main {:entries [prod] :init-fn prod/-main}}
         :module-hash-names true
         ;; :parallel-build false forces shadow's single-threaded
         ;; seq-compile path (shadow.build.compiler/compile-cljs-sources).
         ;; Electric's dual macro-compiler resolves aliased element macros
         ;; (e.g. svg/line in freememo.icons) via a SHARED cljs-analyzer atom
         ;; that it populates with a best-effort `safe-require`. Under shadow's
         ;; default parallel compile, that require can lose a race and fail
         ;; silently, leaving the macro unresolved so the form leaks unexpanded
         ;; -> "Can't take value of a macro: #'hyperfiddle.electric-svg3/line".
         ;; The failure is CPU-count/timing dependent (hits multi-core CI/Docker
         ;; builds, usually misses local builds) and the reported file/line is
         ;; misattributed to whatever ns was compiling concurrently. Serial
         ;; compile removes the race. Closure :advanced optimization still runs
         ;; multi-threaded (:closure-threads), so the release-build cost is small.
         :compiler-options {:infer-externs :auto
                            :parallel-build false}}
  :prod-jetty9 {:target :browser
                :output-dir "resources/public/freememo/js"
                :asset-path "/freememo/js"
                :modules {:main {:entries [prod-jetty9] :init-fn prod-jetty9/-main}}
                :module-hash-names true
                :compiler-options {:parallel-build false}}}}
