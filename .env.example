# Copy to .env and edit before running prod:
#   APP_VERSION=$(git describe --tags --long --always --dirty) \
#     docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
# DB_HOST / DB_PORT / DB_NAME / DB_USER / DB_PASSWORD, PORT, and PROD are set by
# docker-compose.prod.yml — not here. The app reuses the existing pgdata volume,
# whose DB password was fixed at first init (see docker-compose.yml).

# --- Required ---

# Session cookie encryption key. Generate with: openssl rand -hex 32
ENC_KEY_SECRET=change-me

# --- Optional ---

# Server-wide fallback OpenAI key, used only when a user hasn't set their own.
# OPENAI_DEMO_KEY=

# Storage caps. 0 = unlimited (self-host default).
# Set to a byte count to enforce a cap, e.g. 5368709120 for 5 GB total / 209715200 for 200 MB per file.
# STORAGE_QUOTA_BYTES=0
# STORAGE_PER_FILE_MAX_BYTES=0

# Public base URL — embedded in Anki card source anchors and other self-links.
# APP_BASE_URL=http://localhost:8080

# Google OAuth — required for sign-in (no local-only login). Get credentials from
# https://console.cloud.google.com/apis/credentials and register the redirect URI.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Log level. trace | debug | info | warn | error | fatal
# LOG_LEVEL=info
