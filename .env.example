# Copy to .env and edit before running prod:
#   APP_VERSION=$(git describe --tags --long --always --dirty) \
#     docker compose -f docker-compose.yml -f docker-compose.prod.yml up -d --build
#
# DB_HOST / DB_PORT / DB_NAME, PORT, and PROD are set by docker-compose.prod.yml.

# --- Required ---

# Database password. Set this BEFORE the first `up` — Postgres fixes it at init
# and cannot rotate it via env afterward. Feeds both the postgres and app services.
# Generate with: openssl rand -hex 32
DB_PASSWORD=change-me

# Session cookie encryption key. Generate with: openssl rand -hex 32
ENC_KEY_SECRET=change-me

# --- Auth ---

# Which login controls to surface: password | google | both
# Self-host default is "password" (no Google setup needed).
AUTH_MODE=password

# Seed an initial account at boot. Created only if the username is absent —
# changing ADMIN_PASSWORD later does NOT reset an existing account.
ADMIN_USER=admin
ADMIN_PASSWORD=change-me

# Session cookie Secure attribute. MUST be false to log in over plain HTTP
# (localhost/LAN without TLS). Set true (default) only behind an HTTPS proxy.
COOKIE_SECURE=false

# --- AI keys ---

# Card generation (OpenAI). Required for flashcard generation.
OPENAI_API_KEY=

# OCR text extraction (OpenRouter). Required for scanning documents — OCR does
# NOT use the OpenAI key. Get a key at https://openrouter.ai/keys
PLATFORM_OPENROUTER_API_KEY=

# --- Optional ---

# Google OAuth — only needed when AUTH_MODE is google or both. Get credentials
# from https://console.cloud.google.com/apis/credentials and register the redirect URI.
# GOOGLE_CLIENT_ID=
# GOOGLE_CLIENT_SECRET=
# GOOGLE_REDIRECT_URI=http://localhost:8080/auth/google/callback

# Storage caps. 0 = unlimited (self-host default).
# Set to a byte count to enforce a cap, e.g. 5368709120 for 5 GB total / 209715200 for 200 MB per file.
# STORAGE_QUOTA_BYTES=0
# STORAGE_PER_FILE_MAX_BYTES=0

# Public base URL — embedded in Anki card source anchors and other self-links.
# APP_BASE_URL=http://localhost:8080

# Log level. trace | debug | info | warn | error | fatal
# LOG_LEVEL=info
